<%- include('../partials/header') %>

<!-- ── HERO SECTION ─────────────────────────── -->
<section class="hero">
  <div class="hero-bg-shapes">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>
  
  <div class="container hero-content">
    <div class="hero-text animate-fade-up">
      <div class="hero-badge">
        <i data-lucide="siren"></i> <%= t.hero_badge %>
      </div>
      
      <h1>
        <%= t.hero_title_1 %><br>
        <span class="gradient-text"><%= t.hero_title_2 %></span>
      </h1>
      
      <p class="hero-subtitle">
        <%= t.hero_subtitle %>
      </p>
      
      <div class="hero-actions">
        <a href="/report?lang=<%= lang %>" class="btn btn-primary btn-lg">
          <i data-lucide="alert-circle"></i> <%= t.hero_btn_report %>
          <span class="btn-ripple"></span>
        </a>
        <a href="#how-it-works" class="btn btn-outline btn-lg">
          <i data-lucide="play-circle"></i> <%= t.hero_btn_learn %>
        </a>
      </div>
    </div>
    
    <div class="hero-visual animate-fade-up delay-200">
      <div class="hero-card">
        <div class="hero-card-icon text-primary"><i data-lucide="map-pin"></i></div>
        <div>
          <h3><%= t.hero_card1_title %></h3>
          <p><%= t.hero_card1_desc %></p>
        </div>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon text-purple"><i data-lucide="map"></i></div>
        <div>
          <h3><%= t.hero_card2_title %></h3>
          <p><%= t.hero_card2_desc %></p>
        </div>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon text-accent"><i data-lucide="activity"></i></div>
        <div>
          <h3><%= t.hero_card3_title %></h3>
          <p><%= t.hero_card3_desc %></p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── LIVE STATS ───────────────────────────── -->
<section class="stats-section">
  <div class="container stats-grid">
    <div class="stat-card animate-fade-up delay-100">
      <div class="stat-icon pending">
        <i data-lucide="files"></i>
      </div>
      <div class="stat-number" data-target="<%= stats.total %>">0</div>
      <div class="stat-label"><%= t.stat_total %></div>
    </div>
    
    <div class="stat-card animate-fade-up delay-200">
      <div class="stat-icon rescued">
        <i data-lucide="heart"></i>
      </div>
      <div class="stat-number" data-target="<%= stats.rescued %>">0</div>
      <div class="stat-label"><%= t.stat_rescued %></div>
    </div>
    
    <div class="stat-card animate-fade-up delay-300">
      <div class="stat-icon active">
        <i data-lucide="activity"></i>
      </div>
      <div class="stat-number" data-target="<%= stats.active %>">0</div>
      <div class="stat-label"><%= t.stat_active %></div>
    </div>
  </div>
</section>

<!-- ── OUR MISSION ──────────────────────────── -->
<section id="mission" class="page-section mission-section">
  <div class="container">
    <div class="section-header animate-fade-up">
      <span class="section-tag"><%= t.mission_tag %></span>
      <h2><%= t.mission_title %></h2>
      <p><%= t.mission_desc %></p>
    </div>
    
    <div class="mission-grid">
      <div class="mission-card animate-fade-up delay-100">
        <div class="mission-icon text-info"><i data-lucide="users"></i></div>
        <h3><%= t.mission1_title %></h3>
        <p><%= t.mission1_desc %></p>
      </div>
      <div class="mission-card animate-fade-up delay-200">
        <div class="mission-icon text-danger"><i data-lucide="zap"></i></div>
        <h3><%= t.mission2_title %></h3>
        <p><%= t.mission2_desc %></p>
      </div>
      <div class="mission-card animate-fade-up delay-300">
        <div class="mission-icon text-purple"><i data-lucide="bar-chart-2"></i></div>
        <h3><%= t.mission3_title %></h3>
        <p><%= t.mission3_desc %></p>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ─────────────────────────── -->
<section id="how-it-works" class="page-section how-section">
  <div class="container">
    <div class="section-header animate-fade-up">
      <span class="section-tag"><%= t.how_tag %></span>
      <h2><%= t.how_title %></h2>
    </div>
    
    <div class="steps-grid">
      <div class="step-card animate-fade-up delay-100">
        <div class="step-number">1</div>
        <h3><%= t.step1 %></h3>
        <p><%= t.step1_desc %></p>
      </div>
      
      <i data-lucide="chevron-right" class="step-connector animate-fade-up delay-200"></i>
      
      <div class="step-card animate-fade-up delay-200">
        <div class="step-number">2</div>
        <h3><%= t.step2 %></h3>
        <p><%= t.step2_desc %></p>
      </div>
      
      <i data-lucide="chevron-right" class="step-connector animate-fade-up delay-300"></i>
      
      <div class="step-card animate-fade-up delay-300">
        <div class="step-number">3</div>
        <h3><%= t.step3 %></h3>
        <p><%= t.step3_desc %></p>
      </div>
    </div>
  </div>
</section>

<!-- ── CALL TO ACTION ───────────────────────── -->
<section class="page-section cta-section">
  <div class="container">
    <div class="cta-card animate-fade-up">
      <h2><%= t.cta_title %></h2>
      <p><%= t.cta_desc %></p>
      <a href="/report?lang=<%= lang %>" class="btn btn-lg">
        <i data-lucide="alert-circle"></i> <%= t.hero_btn_report %>
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
