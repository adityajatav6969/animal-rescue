<%- include('../partials/header') %>

<section class="page-section">
  <div class="container container-md">
    <div class="feature-hero animate-fade-up">
      <span class="section-tag">💬 Community</span>
      <h1>Community <span class="gradient-text">Forum</span></h1>
      <p>Discuss animal rescue topics, share experiences, and connect with fellow rescuers.</p>
    </div>

    <!-- New Post Form -->
    <div class="feature-form animate-fade-up delay-100" style="margin-bottom:2rem;">
      <h2><i data-lucide="edit-3"></i> Create a Post</h2>
      <form method="POST" action="/community">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Your Name</label>
            <input type="text" name="author" class="form-input" required placeholder="Your name" />
          </div>
          <div class="form-group">
            <label class="form-label">Post Title</label>
            <input type="text" name="title" class="form-input" required placeholder="Discussion topic" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Content</label>
          <textarea name="content" class="form-input form-textarea" required placeholder="Share your thoughts..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary">
          <i data-lucide="send"></i> Post
        </button>
      </form>
    </div>

    <!-- Posts -->
    <div class="animate-fade-up delay-200">
      <% if (posts.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">💬</div>
          <p>No discussions yet. Be the first to start a conversation!</p>
        </div>
      <% } else { %>
        <% posts.forEach(post => { %>
          <div class="forum-post">
            <div class="forum-post-header">
              <h3><%= post.title %></h3>
              <span class="forum-post-meta"><%= post.author %> · <%= new Date(post.createdAt).toLocaleDateString() %></span>
            </div>
            <p><%= post.content %></p>

            <% if (post.comments && post.comments.length > 0) { %>
              <div class="forum-comments">
                <% post.comments.forEach(c => { %>
                  <div class="forum-comment">
                    <strong><%= c.author %></strong>
                    <p><%= c.content %></p>
                  </div>
                <% }) %>
              </div>
            <% } %>

            <form method="POST" action="/community/<%= post._id %>/comment" class="comment-form">
              <input type="text" name="author" class="form-input form-input-sm" placeholder="Name" required style="max-width:120px;" />
              <input type="text" name="content" class="form-input form-input-sm" placeholder="Add a comment..." required />
              <button type="submit" class="btn btn-primary btn-sm"><i data-lucide="send"></i></button>
            </form>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
