<%- include('../partials/header') %>

<section class="page-section">
  <div class="container">
    <div class="feature-hero animate-fade-up">
      <span class="section-tag">💚 Stories</span>
      <h1>Rescue <span class="gradient-text">Stories</span></h1>
      <p>Inspiring stories of animals who were rescued and given a new life.</p>
    </div>

    <% if (stories.length === 0) { %>
      <div class="empty-state animate-fade-up delay-100">
        <div class="empty-icon">📖</div>
        <p>No rescue stories yet. Check back soon for inspiring stories!</p>
      </div>
    <% } else { %>
      <div class="feature-cards-grid animate-fade-up delay-100">
        <% stories.forEach(story => { %>
          <div class="feature-card">
            <div class="feature-card-img">
              <% if (story.afterPhoto) { %>
                <img src="<%= story.afterPhoto %>" alt="<%= story.title %>" />
              <% } else { %>
                🐾
              <% } %>
            </div>
            <div class="feature-card-body">
              <div class="feature-card-meta">
                <span class="badge badge-type"><%= story.animalType %></span>
                <% if (story.location) { %>
                  <span class="text-muted" style="font-size:0.8rem"><i data-lucide="map-pin" style="width:14px;height:14px;display:inline"></i> <%= story.location %></span>
                <% } %>
              </div>
              <h3><%= story.title %></h3>
              <p><%= story.description.substring(0, 150) %>...</p>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.5rem;">
                <span class="text-muted" style="font-size:0.8rem"><%= new Date(story.rescueDate).toLocaleDateString() %></span>
                <a href="/rescue-stories/<%= story._id %>" class="btn btn-outline btn-sm">Read More</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
