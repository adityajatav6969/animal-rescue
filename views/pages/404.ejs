<%- include('../partials/header') %>

<section class="page-section error-page text-center">
  <div class="container container-sm animate-fade-up">
    <div class="error-icon text-muted">
      <i data-lucide="compass" style="width: 80px; height: 80px;"></i>
    </div>
    
    <h1>404 - Page Not Found</h1>
    <p>We couldn't find the page you're looking for. It might have been moved or deleted.</p>
    
    <a href="/?lang=<%= typeof lang !== 'undefined' ? lang : 'en' %>" class="btn btn-primary mt-2">
      <i data-lucide="home"></i> Back to Home
    </a>
  </div>
</section>

<%- include('../partials/footer') %>
