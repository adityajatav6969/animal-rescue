<%- include('../partials/header') %>

<section class="page-section">
  <div class="container container-md">
    <div class="animate-fade-up" style="margin-bottom:2rem;">
      <a href="/adopt" class="btn btn-outline btn-sm"><i data-lucide="arrow-left"></i> Back to Adoption</a>
    </div>
    <div class="feature-form animate-fade-up delay-100" style="max-width:100%;">
      <div style="display:flex;gap:2rem;align-items:flex-start;flex-wrap:wrap;">
        <div style="flex:1;min-width:200px;text-align:center;">
          <% if (animal.photo) { %>
            <img src="<%= animal.photo %>" alt="<%= animal.animalName %>" style="width:100%;border-radius:var(--radius-lg);max-height:350px;object-fit:cover;" />
          <% } else { %>
            <div style="font-size:6rem;padding:2rem;">
              <% if (animal.animalType === 'dog') { %>🐕<% } else if (animal.animalType === 'cat') { %>🐈<% } else if (animal.animalType === 'bird') { %>🐦<% } else { %>🐾<% } %>
            </div>
          <% } %>
        </div>
        <div style="flex:1;min-width:250px;">
          <div class="feature-card-meta" style="margin-bottom:0.75rem;">
            <span class="badge badge-type"><%= animal.animalType %></span>
            <span class="badge badge-<%= animal.healthStatus %>"><%= animal.healthStatus %></span>
          </div>
          <h1 style="font-size:2rem;margin-bottom:0.5rem;"><%= animal.animalName %></h1>
          <% if (animal.age) { %><p style="margin-bottom:0.5rem;"><strong>Age:</strong> <%= animal.age %></p><% } %>
          <% if (animal.location) { %><p style="color:var(--text-muted);margin-bottom:1rem;"><i data-lucide="map-pin" style="width:14px;height:14px;display:inline"></i> <%= animal.location %></p><% } %>
          <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:1.5rem;"><%= animal.description || 'A wonderful animal looking for a forever home.' %></p>
          <a href="mailto:adopt@rescuenet.org?subject=Adoption Request for <%= animal.animalName %>" class="btn btn-primary btn-lg">
            <i data-lucide="heart"></i> Request Adoption
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
