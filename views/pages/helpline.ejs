<%- include('../partials/header') %>

<section class="page-section">
  <div class="container">
    <div class="feature-hero animate-fade-up">
      <span class="section-tag">📞 Helplines</span>
      <h1>Animal <span class="gradient-text">Helpline Directory</span></h1>
      <p>Official emergency and welfare numbers for animal rescue across India.</p>
    </div>

    <div class="helpline-grid animate-fade-up delay-100">
      <div class="helpline-card">
        <div class="helpline-icon">🏛️</div>
        <h3>Animal Welfare Board of India</h3>
        <p>Government body for animal protection and welfare policies.</p>
        <a href="tel:01123357088" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 011-2335 7088
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🌲</div>
        <h3>Forest Department</h3>
        <p>Report wildlife emergencies and illegal poaching activities.</p>
        <a href="tel:1800114100" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 1800-114-100
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🐾</div>
        <h3>SPCA India</h3>
        <p>Prevention of cruelty to animals and rescue operations.</p>
        <a href="tel:01124679532" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 011-2467 9532
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🦁</div>
        <h3>Wildlife SOS</h3>
        <p>24/7 wildlife rescue and rehabilitation helpline.</p>
        <a href="tel:+919917109666" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> +91 9917 109 666
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🏢</div>
        <h3>Municipal Animal Control</h3>
        <p>Local municipal services for stray animal management.</p>
        <a href="tel:1800112255" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 1800-112-255
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🆘</div>
        <h3>PFA (People for Animals)</h3>
        <p>India's largest animal welfare organization helpline.</p>
        <a href="tel:+911124621939" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 011-2462 1939
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🐄</div>
        <h3>Gaushala Helpline</h3>
        <p>For reporting injured or abandoned cattle and cows.</p>
        <a href="tel:14400" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 14400
        </a>
      </div>

      <div class="helpline-card">
        <div class="helpline-icon">🚔</div>
        <h3>Police (Animal Cruelty)</h3>
        <p>Report animal cruelty and abuse to the police.</p>
        <a href="tel:100" class="helpline-number">
          <i data-lucide="phone" style="width:16px;height:16px;"></i> 100
        </a>
      </div>
    </div>

    <div class="info-grid animate-fade-up delay-200">
      <div class="info-card text-center">
        <div class="info-card-icon">📱</div>
        <h3>Quick SOS</h3>
        <p>Use our SOS button for instant emergency rescue requests.</p>
        <a href="/emergency" class="btn btn-danger btn-sm" style="margin-top:0.75rem">🚨 Emergency SOS</a>
      </div>
      <div class="info-card text-center">
        <div class="info-card-icon">🤝</div>
        <h3>Become a Volunteer</h3>
        <p>Join our rescue team and help animals in distress.</p>
        <a href="/volunteer" class="btn btn-outline btn-sm" style="margin-top:0.75rem">Register</a>
      </div>
      <div class="info-card text-center">
        <div class="info-card-icon">📘</div>
        <h3>Care Guide</h3>
        <p>Learn first aid and safe practices for helping animals.</p>
        <a href="/care-guide" class="btn btn-outline btn-sm" style="margin-top:0.75rem">Read Guide</a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
